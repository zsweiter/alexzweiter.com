---
import { computeCurrentLocale } from '@/i18n/utils';
import Languages from '@/components/icons/Languages.astro';

const url = Astro.url;
const languages = [
    { code: 'en', label: 'English', iso: 'EN', icon: '🇬🇧', path: computeCurrentLocale(url, 'en') },
    { code: 'es', label: 'Español', iso: 'ES', icon: '🇪🇸', path: computeCurrentLocale(url, 'es') },
    { code: 'pt', label: 'Português', iso: 'PT', icon: '🇵🇹', path: computeCurrentLocale(url, 'pt') }
];

const { current = 'en', onChange, class: className } = Astro.props;
