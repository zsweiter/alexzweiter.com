<div class:list={['relative inline-block text-left', className]}>
    <button
        class="cursor-pointer min-w-[4ch]"
        type="button"
        aria-haspopup="listbox"
        aria-expanded="false"
        id="language-picker-button"
        onclick="document.getElementById('language-picker-list').classList.toggle('hidden')"
    >
        <span class="flex items-center gap-2 flex-col">
            <Languages class="size-4" />
            <span class="text-sm">{languages.find(lang => lang.code === current)?.iso}</span>
        </span>
    </button>

    <ul
        id="language-picker-list"
        class="hidden absolute mt-1 w-full bg-slate-200/50 border border-primary-400 rounded-md shadow-lg z-10"
        role="listbox"
        aria-labelledby="language-picker-button"
    >
        {
            languages.map(lang => (
                <li
                    role="option"
                    class="cursor-pointer flex items-center gap-2 p-2 hover:bg-primary-50 hover:text-primary-600 transition"
                >
                    <a href={lang.path} title={lang.label}>
                        {lang.icon}
                    </a>
                </li>
            ))
        }
    </ul>
</div>
