---
import Layout from '@/layouts/Layout.astro';

interface Props {
    seo: {
        title: string;
        description: string;
    };
    posts: {
        slug: string;
        data: {
            title: string;
            description: string;
            pubDate: Date;
            heroImage?: string;
        };
    }[];
}

const { seo, posts } = Astro.props;
---

<Layout title={seo.title} description={seo.description}>
    <section class="p-container min-h-vh py-20 lg:pt-30">
        <header class="mb-16" data-ws-reveal>
            <h1 class="font-sans tracking-widest leading-tight text-5xl md:text-8xl font-semibold text-primary-500">
                <span class="text-slate-300/80">Blog</span>
            </h1>
            <p class="text-slate-400 mt-4 text-lg max-w-xl">
                {seo.description}
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8" data-ws-staggered>
            {
                posts.map((post) => (
                    <a
                        href={`/blog/${post.slug}`}
                        class="group block"
                    >
                        <article class="h-full bg-gradient-to-b from-slate-900/80 to-slate-900/40 border border-slate-800/60 rounded-xl overflow-hidden hover:border-primary-500/40 hover:shadow-lg hover:shadow-primary-500/5 transition-all duration-500 hover:-translate-y-1">
                            {post.data.heroImage && (
                                <div class="aspect-[16/10] overflow-hidden">
                                    <img
                                        src={post.data.heroImage}
                                        alt={post.data.title}
                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                    />
                                </div>
                            )}
                            <div class="p-6 flex flex-col h-[calc(100%-60%)]">
                                <time class="text-xs font-mono text-primary-500/80 uppercase tracking-wider" datetime={post.data.pubDate.toISOString()}>
                                    {post.data.pubDate.toLocaleDateString('en-US', {
                                        year: 'numeric',
                                        month: 'short',
                                        day: 'numeric'
                                    })}
                                </time>
                                <h2 class="text-lg font-semibold text-primary-100 mt-3 group-hover:text-primary-400 transition-colors line-clamp-2">
                                    {post.data.title}
                                </h2>
                                <p class="text-slate-400/80 text-sm mt-3 line-clamp-3 flex-grow">
                                    {post.data.description}
                                </p>
                                <div class="mt-4 flex items-center text-primary-500/60 text-sm font-medium group-hover:text-primary-400 transition-colors">
                                    <span>Read more</span>
                                    <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </div>
                            </div>
                        </article>
                    </a>
                ))
            }
        </div>
    </section>
</Layout>
