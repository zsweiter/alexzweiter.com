---
import Layout from '@/layouts/Layout.astro';
import Download from '../icons/Download.astro';
import Mails from '../icons/Mails.astro';
import GitHub from '../icons/GitHub.astro';
import Linkedin from '../icons/Linkedin.astro';
import TechBrand from '../icons/TechBrand.astro';

interface Props {
    seo: {
        title: string;
        description: string;
    };

    title: string;
    bio: string[];
    stack: {
        title: string;
        items: Array<{
            category: string;
            items: string[];
        }>;
    };
    experience: {
        title: string;
        items: {
            company: string;
            location: string;
            period: string;
            role: string;
            achievements: string[];
        }[];
    };
}

const { stack, experience, seo, title, bio } = Astro.props;

const [firstPart, secondPart] = title.split('|');
---

<Layout title={seo.title} description={seo.description}>
    <section class="pg-about p-container w-full min-h-vh pt-32 px-6 md:px-24 pb-24">
        <div class="lg:col-span-5 lg:pr-8" data-ws-staggered>
            <section>
                <h1
                    class="text-5xl md:text-7xl uppercase tracking-[0.2em] text-slate-200/80 font-bold mb-6 flex items-center gap-2"
                >
                    {firstPart}<span class="text-primary-500">{secondPart}</span>
                </h1>
                <div class="flex flex-wrap gap-4 py-6">
                    <a
                        href="/docs/alex-resume.pdf"
                        download="alex-resume.pdf"
                        class="flex items-center gap-2 px-6 py-3 bg-slate-900/40 border border-transparent hover:border-primary-500/50 transition-all duration-500 border-slate-800/50 text-white font-bold cursor-pointer"
                    >
                        <Download class:list={'size-4'} /> Resume
                    </a>
                    <div class="flex items-center gap-4 px-4 py-3">
                        <a data-social="email" class="text-slate-400 hover:text-white transition-colors cursor-pointer">
                            <Mails class:list={'size-5'} />
                        </a>
                        <a
                            data-social="linkedin"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 hover:text-primary-400 transition-colors cursor-pointer"
                        >
                            <Linkedin class="size-5" />
                        </a>
                        <a
                            data-social="github"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 hover:text-white transition-colors cursor-pointer"
                        >
                            <GitHub class:list={'size-5'} />
                        </a>
                        <a
                            data-social="twitter"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 hover:text-white transition-colors cursor-pointer"
                        >
                            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"
                                ><path
                                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                                ></path></svg
                            >
                        </a>
                        <a
                            data-social="instagram"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 hover:text-white transition-colors cursor-pointer"
                        >
                            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"
                                ><path
                                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                                ></path></svg
                            >
                        </a>
                        <a
                            data-social="soundcloud"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-slate-400 hover:text-primary-500 transition-colors cursor-pointer"
                        >
                            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"
                                ><path
                                    d="M1.175 12.225c-.051 0-.094.046-.101.1l-.233 2.154.233 2.105c.007.058.05.098.101.098.05 0 .09-.04.099-.098l.255-2.105-.27-2.154c-.009-.06-.052-.1-.084-.1zm-.899 1.624c-.057 0-.09.05-.103.108l-.198 1.545.198 1.492c.013.057.046.108.103.108.057 0 .09-.051.103-.108l.226-1.492-.226-1.545c-.013-.058-.046-.108-.103-.108zm1.799-1.699c-.057 0-.104.05-.111.11l-.226 2.086.226 2.054c.007.06.054.111.111.111.056 0 .097-.051.111-.111l.256-2.054-.256-2.086c-.014-.06-.055-.11-.111-.11zm.899-.247c-.057 0-.103.05-.11.11l-.198 2.333.198 2.29c.007.06.053.111.11.111.057 0 .097-.051.111-.111l.226-2.29-.226-2.333c-.014-.06-.054-.11-.111-.11zm.899-.188c-.057 0-.104.05-.111.11l-.17 2.52.17 2.478c.007.059.054.111.111.111.056 0 .097-.052.11-.111l.198-2.478-.198-2.52c-.013-.06-.053-.11-.11-.11zm.908-.192c-.059 0-.109.055-.116.116l-.17 2.712.17 2.664c.007.061.057.116.116.116.058 0 .102-.055.115-.116l.192-2.664-.192-2.712c-.013-.061-.057-.116-.115-.116zm.908-.188c-.059 0-.109.054-.115.115l-.155 2.9.155 2.853c.006.061.056.115.115.115.058 0 .102-.054.115-.115l.175-2.853-.175-2.9c-.013-.061-.057-.115-.115-.115zm3.6-.314c-.059 0-.109.054-.116.116l-.155 3.213.155 3.166c.007.062.057.116.116.116.058 0 .102-.054.115-.116l.176-3.166-.176-3.213c-.013-.062-.057-.116-.115-.116zm.908-.196c-.059 0-.109.054-.116.116l-.155 3.409.155 3.363c.007.062.057.116.116.116.058 0 .102-.054.115-.116l.176-3.363-.176-3.409c-.013-.062-.057-.116-.115-.116zm.908-.2c-.059 0-.109.054-.115.116l-.14 3.61.14 3.562c.006.062.056.116.115.116.059 0 .103-.054.116-.116l.16-3.562-.16-3.61c-.013-.062-.057-.116-.116-.116zm.908-.203c-.059 0-.109.054-.115.115l-.14 3.813.14 3.766c.006.061.056.115.115.115.059 0 .103-.054.116-.115l.159-3.766-.159-3.813c-.013-.061-.057-.115-.116-.115zm.909-.207c-.059 0-.11.055-.116.116l-.14 4.017.14 3.969c.006.061.057.116.116.116.058 0 .102-.055.115-.116l.16-3.969-.16-4.017c-.013-.061-.057-.116-.115-.116zm.908-.211c-.059 0-.11.055-.116.116l-.125 4.22.125 4.173c.006.061.057.116.116.116.058 0 .102-.055.115-.116l.14-4.173-.14-4.22c-.013-.061-.057-.116-.115-.116zm.908-.215c-.059 0-.11.055-.115.116l-.125 4.424.125 4.376c.006.062.056.116.115.116.059 0 .103-.054.116-.116l.14-4.376-.14-4.424c-.013-.061-.057-.116-.116-.116zm2.719-.632c-.058 0-.109.055-.115.115l-.125 4.653.125 4.605c.006.062.057.116.115.116.059 0 .103-.054.116-.116l.14-4.605-.14-4.653c-.013-.06-.057-.115-.116-.115zm.909-.222c-.058 0-.11.054-.115.115l-.11 4.875.11 4.826c.005.061.057.115.115.115.058 0 .102-.054.115-.115l.125-4.826-.125-4.875c-.013-.061-.057-.115-.115-.115zm.908-.226c-.058 0-.11.054-.115.115l-.11 5.077.11 5.028c.005.062.057.115.115.115.059 0 .103-.053.116-.115l.124-5.028-.124-5.077c-.013-.061-.057-.115-.116-.115zm.908-.23c-.058 0-.11.054-.115.115l-.095 5.279.095 5.23c.006.062.057.115.115.115.058 0 .102-.053.115-.115l.11-5.23-.11-5.279c-.013-.061-.057-.115-.115-.115zm.909-.234c-.058 0-.11.054-.115.115l-.095 5.481.095 5.432c.006.062.057.115.115.115.058 0 .102-.053.115-.115l.11-5.432-.11-5.481c-.013-.061-.057-.115-.115-.115zm.908-.238c-.058 0-.11.054-.115.115l-.095 5.683.095 5.635c.006.061.057.115.115.115.058 0 .102-.054.115-.115l.11-5.635-.11-5.683c-.013-.061-.057-.115-.115-.115zm.908-.242c-.058 0-.11.054-.115.115l-.08 5.885.08 5.836c.006.062.057.115.115.115.058 0 .102-.053.115-.115l.095-5.836-.095-5.885c-.013-.061-.057-.115-.115-.115zm.909-.245c-.058 0-.11.054-.115.115l-.08 6.087.08 6.038c.006.062.057.115.115.115.058 0 .102-.053.115-.115l.095-6.038-.095-6.087c-.013-.061-.057-.115-.115-.115zm.908-.249c-.058 0-.11.054-.115.115l-.08 6.289.08 6.24c.006.062.057.115.115.115.058 0 .102-.053.115-.115l.095-6.24-.095-6.289c-.013-.061-.057-.115-.115-.115zm.908-.253c-.058 0-.11.054-.115.115l-.065 6.491.065 6.442c.006.061.057.115.115.115.058 0 .102-.054.115-.115l.08-6.442-.08-6.491c-.013-.061-.057-.115-.115-.115zm.908-.257c-.058 0-.11.054-.115.115l-.065 6.693.065 6.645c.006.061.057.115.115.115.058 0 .102-.054.115-.115l.08-6.645-.08-6.693c-.013-.061-.057-.115-.115-.115zm.909-.261c-.058 0-.11.054-.115.115l-.065 6.895.065 6.846c.006.062.057.116.115.116.058 0 .102-.054.115-.116l.08-6.846-.08-6.895c-.013-.061-.057-.115-.115-.115zm.908-.265c-.058 0-.11.054-.115.115l-.05 7.097.05 7.048c.006.062.057.116.115.116.058 0 .102-.054.115-.116l.065-7.048-.065-7.097c-.013-.061-.057-.115-.115-.115zm.908-.269c-.058 0-.11.054-.115.115l-.05 7.299.05 7.25c.006.062.057.116.115.116.058 0 .102-.054.115-.116l.065-7.25-.065-7.299c-.013-.061-.057-.115-.115-.115zm.908-.272c-.058 0-.11.054-.115.115l-.035 7.501.035 7.452c.006.062.057.116.115.116.058 0 .102-.054.115-.116l.05-7.452-.05-7.501c-.013-.062-.057-.116-.115-.116zm2.719-.677c-.058 0-.11.055-.115.116l-.035 7.803.035 7.754c.006.062.057.116.115.116.059 0 .103-.054.116-.116l.05-7.754-.05-7.803c-.013-.061-.057-.116-.116-.116zm.908-.283c-.058 0-.11.055-.115.116l-.02 8.005.02 7.956c.006.062.057.116.115.116.059 0 .103-.054.116-.116l.035-7.956-.035-8.005c-.013-.061-.057-.116-.116-.116z"
                                ></path></svg
                            >
                        </a>
                    </div>
                </div>
            </section>
            <div
                class="font-p text-base space-y-6 text-slate-300 leading-relaxed backdrop-blur-sm bg-black/20 p-6 border-l border-primary-500"
            >
                {bio.map((paragraph: string) => <p>{paragraph}</p>)}
            </div>
        </div>

        <section class="lg:pr-8 pt-16" data-ws-staggered>
            <h3 class="text-base uppercase tracking-[0.3em] text-primary-500 font-bold flex items-center py-6">
                {stack.title}
            </h3>
            <div class="grid md:grid-cols-2 gap-4">
                {
                    stack.items.map(stack => (
                        <div class="p-4 bg-primary-900/10 transition-all duration-500">
                            <h4 class="text-white font-p text-sm mb-2 uppercase tracking-tighter flex items-center gap-2 opacity-70">
                                {stack.category}
                            </h4>
                            <ul class="text-base text-slate-400 space-y-1 flex gap-4 flex-wrap">
                                {stack.items.map(item => (
                                    <li class="hover:text-primary-400 transition-colors pointer-events-none flex items-center gap-2">
                                        <TechBrand icon={item as any} />
                                        <span>{item}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </section>
    </section>

    <section class="p-container w-full pb-36">
        <h3
            class="text-base uppercase tracking-[0.3em] text-primary-500 font-bold mb-8 flex items-center gap-2"
            data-ws-fade
        >
            {experience.title}
        </h3>

        <div class="space-y-12" data-ws-staggered>
            {
                experience.items.map(job => (
                    <div class="relative pl-8 border-l border-slate-800">
                        <div class="absolute -left-1 top-0 size-2 bg-primary-500 rounded-full" />

                        <div class="mb-2">
                            <span class="text-red-400 font-p text-sm uppercase tracking-widest">{job.period}</span>
                            <h4 class="text-2xl font-medium tracking-wider text-white">{job.role}</h4>
                            <p class="text-slate-400 text-base font-medium italic">
                                {job.company} — {job.location}
                            </p>
                        </div>

                        <ul class="mt-4 space-y-3">
                            {job.achievements.map(achievement => (
                                <li class="font-p text-slate-300 leading-relaxed flex gap-3">{achievement}</li>
                            ))}
                        </ul>
                    </div>
                ))
            }
        </div>
    </section>
</Layout>

<script>
    const socials = {
        github: 'https://github.com/zsweiter',
        linkedin: 'https://www.linkedin.com/in/alex-segundo',
        twitter: 'https://x.com/asegundo442',
        instagram: 'https://www.instagram.com/alexsegundoll',
        soundcloud: 'https://soundcloud.com/alex-zweiter',
        email: 'zsweiter@gmail.com'
    };

    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('[data-social]').forEach(el => {
            const key = el.getAttribute('data-social') as keyof typeof socials;
            const value = socials[key];
            if (value) {
                if (key === 'email') {
                    el.setAttribute('href', `mailto:${value}`);
                } else {
                    el.setAttribute('href', value);
                }
            }
        });
    });
</script>
