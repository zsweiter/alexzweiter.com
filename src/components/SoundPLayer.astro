---
interface Props {
    playlist: Array<{
        title: string;
        artist: string;
        poster: string;
        src: string;
    }>;
}

const { playlist = [] } = Astro.props;

function formatTime(seconds: number): string {
    if (!seconds || !isFinite(seconds)) return '0:00';
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
}
---

<div class="bg-black/40 backdrop-blur-md p-8 rounded-sm w-full mt-12">
    <div class="flex justify-between items-center mb-6">
        <span class="font-mono text-xs text-tomato animate-pulse">LIVE SIGNAL</span>
        <span class="font-mono text-xs text-gray-500">44.1kHz / 24bit</span>
    </div>

    <div class="flex flex-col gap-8">
        <div class="flex justify-center items-center gap-6">
            <button s-on:click="prevTrack" class="text-gray-500 hover:text-white transition-colors" aria-label="Previous track">
                <span class="font-mono text-xs">[PREV]</span>
            </button>

            <button
                s-on:click="togglePlay"
                class="w-16 h-16 rounded-full border border-primary-500 flex items-center justify-center hover:bg-primary/10 transition-all group cursor-pointer"
                aria-label="audio controls"
            >
                <div
                    class="w-0 h-0 border-t-10 border-t-transparent border-l-16 border-l-primary border-b-10 border-b-transparent ml-1 transition-transform"
                    s-bind:hidden={'isPlaying'}
                >
                </div>
                <div class="w-4 h-6 border-l-4 border-r-4 border-primary-500" s-bind:hidden={'!isPlaying'}></div>
            </button>

            <button s-on:click="nextTrack" class="text-gray-500 hover:text-white transition-colors" aria-label="Next track">
                <span class="font-mono text-xs">[NEXT]</span>
            </button>
        </div>

        <div class="progress-container relative w-full h-2 bg-white/20 rounded cursor-pointer group" s-on:click="onSeek" aria-label="Seek progress">
            <div 
                class="absolute top-0 left-0 h-full bg-primary-500 rounded transition-all duration-100"
                s-style:bind="{width: (progress * 100) + '%'}"
            ></div>
            <div 
                class="absolute top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition-opacity"
                s-style:bind="{left: 'calc(' + (progress * 100) + '% - 6px)'}"
            ></div>
        </div>
        
        <div class="flex justify-between font-mono text-xs text-gray-500">
            <span s-text="formatTime(currentTime)">0:00</span>
            <span s-text="formatTime(duration)">0:00</span>
        </div>

        <div class="flex flex-col gap-2 mt-4 text-left">
            {
                playlist.map((track, i) => (
                    <div
                        class="track-item relative cursor-pointer flex flex-col justify-between p-3 hover:bg-white/5 border border-transparent hover:border-primary-500/30 transition-all group relative"
                        data-index={i}
                    >
                        <button class="flex justify-between items-center cursor-pointer w-full text-left" s-on:click="handlePlayTrack">
                            <div class="flex items-center gap-4">
                                <span class="font-mono text-xs text-gray-600 group-hover:text-primary-500">{`0${i + 1}`}</span>
                                <div class="flex flex-col items-start">
                                    <span class="font-sans text-sm font-bold text-gray-300 group-hover:text-white">
                                        {track.title}
                                    </span>
                                    <span class="font-mono text-[10px] text-gray-500">{track.artist}</span>
                                </div>
                            </div>
                            <span
                                class="font-mono text-xs text-primary-500"
                                s-text={`${i} === currentTrackIndex ? (isPlaying ? "<PLAYING>" : "<PAUSED>") : "<PLAY>"`}
                            />
                        </button>
                    </div>
                ))
            }
        </div>
    </div>
</div>

<script>
    import { inject } from '@packages/z-state';

    document.addEventListener('astro:page-load', () => {
        const state = inject('audioState');
    });
</script>
