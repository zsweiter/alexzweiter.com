---
import HomePage from "@/components/pages/home.astro";
import { getLocaleParams, useTranslations } from "@/i18n/utils";

export async function getStaticPaths() {
    return getLocaleParams();
}

const t = useTranslations(Astro.params.locale as any);
---

<HomePage title={t("web.title")} description={t("web.description")} slogan={t("web.slogan")} />
