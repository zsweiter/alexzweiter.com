---
import AboutPage from '@/components/pages/about.astro';
import { usePageTranslation } from '@/i18n/pages';
import { getLocaleParams } from '@/i18n/utils';

export async function getStaticPaths() {
    return getLocaleParams();
}

const pt = usePageTranslation(Astro.params.locale);
---

<AboutPage
    seo={{
        title: pt('about.seo.title'),
        description: pt('about.seo.description')
    }}
    title={pt('about.title')}
    bio={pt('about.bio', 'array')}
    stack={{
        title: pt('about.stack.title'),
        items: pt('about.stack.items', 'array')
    }}
    experience={{
        title: pt('about.experience.title'),
        items: pt('about.experience.items', 'array')
    }}
/>
