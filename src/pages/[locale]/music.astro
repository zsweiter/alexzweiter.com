---
import MusicPage from "@/components/pages/music.astro";
import { usePageTranslation } from "@/i18n/pages";
import { getLocaleParams } from "@/i18n/utils";

export async function getStaticPaths() {
    return getLocaleParams();
}

const pt = usePageTranslation(Astro.params.locale);
---

<MusicPage
    seo={{
        title: pt("music.seo.title"),
        description: pt("music.seo.description"),
    }}
/>
