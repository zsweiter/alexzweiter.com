---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
	<article class="min-h-vh py-20 lg:pt-30">
		<div class="p-container">
			<header class="mb-12 max-w-4xl" data-ws-reveal>
				<time class="text-sm font-mono text-primary-500/80 uppercase tracking-wider" datetime={post.data.pubDate.toISOString()}>
					{post.data.pubDate.toLocaleDateString("en-US", {
						year: "numeric",
						month: "long",
						day: "numeric",
					})}
				</time>
				<h1 class="font-sans tracking-widest leading-tight text-4xl md:text-6xl font-semibold text-primary-500 mt-4">
					{post.data.title}
				</h1>
				<p class="text-slate-400 mt-4 text-lg max-w-2xl">
					{post.data.description}
				</p>
			</header>

			{post.data.heroImage && (
				<div class="mb-12 rounded-xl overflow-hidden shadow-2xl shadow-black/50">
					<img
						src={post.data.heroImage}
						alt={post.data.title}
						class="w-full max-h-[500px] object-cover"
					/>
				</div>
			)}

			<div class="blog-content max-w-3xl text-slate-300 leading-relaxed" data-ws-staggered>
				<Content />
			</div>
		</div>
	</article>
</Layout>

<style is:global>
	.blog-content h1,
	.blog-content h2,
	.blog-content h3,
	.blog-content h4 {
		font-family: var(--font-sans, sans-serif);
		letter-spacing: 0.1em;
		color: var(--a-blue-400);
		margin-top: 2em;
		margin-bottom: 0.5em;
	}
	.blog-content h1 { font-size: 2rem; }
	.blog-content h2 { font-size: 1.5rem; }
	.blog-content h3 { font-size: 1.25rem; }
	
	.blog-content p {
		margin-bottom: 1.25em;
	}
	
	.blog-content a {
		color: var(--a-blue-400);
		text-decoration: none;
	}
	.blog-content a:hover {
		color: var(--a-blue-300);
	}
	
	.blog-content code {
		color: var(--a-blue-400);
		background: rgba(0, 166, 251, 0.1);
		padding: 0.2em 0.5em;
		border-radius: 4px;
		font-size: 0.9em;
	}
	
	.blog-content pre {
		background: rgba(15, 23, 42, 0.8);
		border: 1px solid rgba(71, 85, 105, 0.5);
		padding: 1em;
		border-radius: 8px;
		overflow-x: auto;
		margin: 1.5em 0;
	}
	
	.blog-content pre code {
		background: transparent;
		padding: 0;
		color: #e2e8f0;
	}
	
	.blog-content ul,
	.blog-content ol {
		margin-bottom: 1.25em;
		padding-left: 1.5em;
	}
	
	.blog-content li {
		margin-bottom: 0.5em;
	}
	
	.blog-content blockquote {
		border-left: 3px solid var(--a-red-400);
		padding-left: 1em;
		margin: 1.5em 0;
		color: var(--a-slate-400);
		font-style: italic;
	}
	
	.blog-content hr {
		border: none;
		border-top: 1px solid rgba(71, 85, 105, 0.5);
		margin: 2em 0;
	}
	
	.blog-content img {
		max-width: 100%;
		border-radius: 8px;
		margin: 1.5em 0;
	}
</style>
