---
import WorksPage from "@/components/pages/works.astro";
import { getLangFromUrl } from "@/i18n/utils";
import { usePageTranslation } from "@/i18n/pages";

const lang = getLangFromUrl(Astro.url);
const pt = usePageTranslation(lang);
---

<WorksPage
    seo={{
        title: pt("works.seo.title"),
        description: pt("works.seo.description"),
    }}
    title={pt("works.title")}
    projects={pt("works.projects", "array")}
/>
